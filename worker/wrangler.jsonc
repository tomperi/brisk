{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brisk",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "account_id": "YOUR_CLOUDFLARE_ACCOUNT_ID",

  // The dashboard (and the browser SDK at /brisk.js) ship as static assets.
  // run_worker_first lets the worker decide when to serve them.
  "assets": {
    "directory": "assets",
    "binding": "ASSETS",
    "run_worker_first": true
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "brisk",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],

  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "brisk"
    }
  ],

  "durable_objects": {
    "bindings": [{ "name": "ROOMS", "class_name": "SiteRoom" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["SiteRoom"] }],

  "vars": {
    // Host your sites hang off of, e.g. "brisk.example.com" → site foo lives
    // at foo.brisk.example.com. Leave empty for path-only mode (/s/foo/),
    // which is what you get on *.workers.dev and local dev.
    "BASE_HOST": "brisk.example.com",
    // "google" turns on Google OAuth for the whole platform (see README).
    // "none" gives every visitor a dev identity — fine on a trusted network.
    "AUTH": "google",
    // Who gets through Google OAuth (comma-separated, either list admits):
    // whole domains, e.g. "yourco.com" — or exact emails for personal
    // instances, e.g. "you@gmail.com" (never allow all of "gmail.com").
    "ALLOWED_EMAIL_DOMAINS": "",
    "ALLOWED_EMAILS": "you@example.com",
    // "public" = demo mode: anyone can view sites and the dashboard without
    // signing in; db/ai/files/realtime and deploys still require login.
    // "private" (the default) gates everything behind login.
    "VISIBILITY": "public"
  },

  "routes": [
    { "pattern": "brisk.example.com", "custom_domain": true },
    { "pattern": "*.brisk.example.com/*", "zone_name": "brisk.example.com" }
  ]

  // Secrets (set with `wrangler secret put <NAME>`):
  //   SESSION_SECRET        — required when AUTH=google; signs session cookies
  //   GOOGLE_CLIENT_ID      — Google OAuth client
  //   GOOGLE_CLIENT_SECRET  — Google OAuth client
  //   DEPLOY_TOKEN          — optional bearer token the CLI uses when AUTH=google
  //   ANTHROPIC_API_KEY     — optional, powers brisk.ai via Claude
  //   OPENAI_API_KEY        — optional, powers brisk.ai via OpenAI

  // To serve wildcard subdomains, add routes on your zone, e.g.:
  // "routes": [
  //   { "pattern": "brisk.example.com", "custom_domain": true },
  //   { "pattern": "*.brisk.example.com/*", "zone_name": "example.com" }
  // ]
}
